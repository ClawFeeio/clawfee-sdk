{
  "name": "clawfee-sdk",
  "version": "0.1.1",
  "description": "ClawFee billing SDK for OpenClaw skill developers",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "license": "MIT",
  "homepage": "https://clawfee.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClawFeeio/clawfee-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/ClawFeeio/clawfee-sdk/issues"
  },
  "keywords": [
    "openclaw",
    "clawfee",
    "billing",
    "ai-agent"
  ],
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
